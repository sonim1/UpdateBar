{
  "name": "@sonim1/updatebar-tui",
  "version": "0.1.0",
  "private": true,
  "description": "Ink terminal UI for UpdateBar",
  "type": "module",
  "bin": {
    "updatebar-tui": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod 755 dist/index.js",
    "dev": "tsx src/index.tsx",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "ink": "7.1.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "eslint": "10.6.0",
    "ink-testing-library": "4.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
